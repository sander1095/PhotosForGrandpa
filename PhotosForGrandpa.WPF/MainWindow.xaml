<Window x:Class="PhotosForGrandpa.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foto en video's organiseren"
        Width="400"
        Height="320"
        MinWidth="400"
        MinHeight="320"
        MaxWidth="400"
        MaxHeight="320"
        Background="White"
        FontFamily="Segoe UI"
        FontSize="12"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20,18,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Width="340"
                   LineHeight="16"
                   TextWrapping="Wrap"
                   Text="Dit programma zal ervoor zorgen dat gedownloade foto's van uw telefoon automatisch gesorteerd worden in de Afbeeldingen en Video map!" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="Stap 1: Download foto's/video's van uw telefoon" />
            <TextBlock Margin="0,4,0,0" Text="Stap 2: Open dit programma" />
            <TextBlock Margin="0,4,0,0" Text="Stap 3: Kies een goede naam voor de map die gemaakt wordt" />
            <TextBlock Margin="0,4,0,0" Text="Stap 4: Klik op de Organiseer knop" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,28,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,7,0,0"
                       Text="Mapnaam" />

            <Grid Grid.Column="2">
                <TextBox x:Name="FolderNameTextBox"
                         Height="28"
                         Padding="8,4"
                         Background="White"
                         BorderBrush="#BFC7D1"
                         Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" />

                <TextBlock Margin="10,6,0,0"
                           Foreground="#888888"
                           IsHitTestVisible="False"
                           Text="Gran Canaria 2019">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=FolderNameTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=FolderNameTextBox}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <Button Grid.Row="4"
                Width="138"
                Height="25"
                HorizontalAlignment="Left"
                Content="Open Google Fotos"
                IsDefault="True"
                Click="Organiseer_DownloadFotos" />
        
        <Button Grid.Row="4"
                Width="138"
                Height="25"
                HorizontalAlignment="Right"
                Content="Organiseer"
                IsDefault="True"
                Click="Organiseer_Click" />
    </Grid>
</Window>
